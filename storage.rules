rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function canParticipate(email) {
      return email == 'jjun8647@gmail.com'
             || firestore.exists(/databases/(default)/documents/friends/$(email));
    }

    match /gallery/{uid}/public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }
    match /gallery/{uid}/private/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }
    // v3.2: connections-tier uploads — readable by the owner or anyone accepted into their
    // friendships/{uid}/friends subcollection (see firestore.rules' isAcceptedFriend()).
    match /gallery/{uid}/connections/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == uid
        || firestore.exists(/databases/(default)/documents/friendships/$(uid)/friends/$(request.auth.uid)));
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }
    match /journal/{uid}/public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }
    match /journal/{uid}/private/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }
    match /journal/{uid}/connections/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == uid
        || firestore.exists(/databases/(default)/documents/friendships/$(uid)/friends/$(request.auth.uid)));
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }

    // Career CMS uploads (project images/documents, certificate files) — owner-only, mirroring
    // firestore.rules' career_* collections being Owner-only rather than canParticipate()-gated.
    match /career/{uid}/public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /career/{uid}/private/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid && request.auth.token.email == 'jjun8647@gmail.com';
    }

    // Time Capsule attachments (v2.9) — always private, no /public split (capsules are never
    // shown to anyone but their own writer).
    match /capsules/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid && canParticipate(request.auth.token.email);
    }
  }
}
