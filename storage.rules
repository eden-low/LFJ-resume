rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /gallery/public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /gallery/private/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.token.email == 'jjun8647@gmail.com'
        || firestore.exists(/databases/(default)/documents/allowedUsers/$(request.auth.token.email))
      );
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
  }
}
